       .content-code {
        font-size: 23px;
        color: #ff0000;
        font-weight: 600;
        font-family: "Roboto", sans-serif;
        letter-spacing: 0em;
      }
      .about-real {
        background-color: #bfe5f2;
        padding: 50px 0px;
      }
      .about-real img {
        width: 100%;
      }
      .about-real .col-md-4 {
        padding-left: 5px !important;
        padding-right: 5px !important;
      }
      .about-real .col-md-7 .row {
        margin-left: 0px;
        margin-right: 0px;
      }

      .about-real .content .icon {
        width: 45px;
        height: 45px;
        background: #fff;
        border-radius: 100px;
        padding: 10px;
        box-shadow: 2px 3px 4px rgba(0, 0, 0, 0.25);
      }
   
      .about-real .content {
        margin-bottom: 20px;
      }
      .about-real .content .text {
        margin-top: 10px;
      }

      .content .text .title {
        font-size: 16px;
        font-weight: 700;
      }
      .content .text .desc {
        font-size: 14px;
      }
      
