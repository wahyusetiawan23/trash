  .list-update {
    background-color: var(--color-dark);
    padding: 50px 0px;
  }

  .list-update .header_update {
    font-size: 1.25rem;
    text-align: center;
    font-weight: 500;
    margin-bottom: 1rem;

  }

  .header_update span {
    color: var(--color-mint);
  }

  .card-update {
    background-color: var(--color-grey);
    font-size: 14px;
    padding: 0.5rem 1rem;
    border-radius: 0.2rem;
    border-left: 4px solid var(--color-mint);
    margin-bottom: 0.5rem;
  }

  .card-update .col-md-3 {
    display: flex;
    justify-content: center;
  }

  .link-update a {
    color: var(--color-mint);
  }

  .link-update a:hover {
    color: var(--color-soft-red);
  }

  .header_update .vis {
    font-size: 1rem;
  }

  .link-update .fa-up-right-from-square {
    color: var(--color-soft-red);
  }
  
  
  
